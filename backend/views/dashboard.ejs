<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
    <link rel="stylesheet" href="dashboard.css">
</head>
<body>

    <h1>Dashboard de Productos</h1>

        <a>
            <button id="agregar-producto">Agregar producto</button>
        </a>

    <% productos.forEach(producto => { %>

        <div class="card">

            <img
                src="<%= producto.imagen %>"
                alt="<%= producto.nombre %>"
                width="200"
            >

            <h2><%= producto.nombre %></h2>

            <p>Categoría: <%= producto.categoria %></p>

            <p>Precio: $<%= producto.precio %></p>

            <p>
                Estado:
                <%= producto.activo ? "Activo" : "Inactivo" %>
            </p>

            <% if(producto.activo) { %>

                <button>Editar</button>

                <button>Eliminar</button>

            <% } else { %>

                <button>Activar</button>

            <% } %>

        </div>

        <hr>

    <% }) %>

    <div id="modal">
        <div class="contenedor-modal">
        
            <div class="top-modal">

            <h1>Carga del producto</h1>
            <button id="cerrar-modal">X</button>

            </div>
            <form action="">

                
                <div class="data">

                    <label for="">Ingrese el nombre del producto:</label>
                    <input type="text" id="input-nombre">
                </div>
                <div class="data">
                    
                    <label for="">Ingrese el precio del producto:</label>
                <input type="text" id="input-precio">
                </div>

                <div class="data">
                    
                    <label for="">Ingrese la url del producto:</label>
                <input type="text" id="input-url">
                </div>
                
                <div class="data">

                    <label for="">Ingrese la categoria del producto:</label>
                <input type="text" id="input-categoria">

                </div>

                <button id="btn-agregar-producto">Agregar producto</button>

                
            </form>



        </div>
        

    </div>
    <script src="/dashboard.js"></script>
</body>
</html>